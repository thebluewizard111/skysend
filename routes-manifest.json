{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/client/checkout/[orderId]",
      "regex": "^/client/checkout/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPorderId": "nxtPorderId"
      },
      "namedRegex": "^/client/checkout/(?<nxtPorderId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/client/orders/[orderId]",
      "regex": "^/client/orders/([^/]+?)(?:/)?$",
